<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Run History"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_delete_all_cloud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete All Cloud Run Data"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/accent_red"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_history_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No runs yet. Start your first session."
        android:textColor="@color/light_gray"
        android:visibility="gone"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history_runs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
