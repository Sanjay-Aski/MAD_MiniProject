<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dark_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_run_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Morning Trail Run"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tv_run_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monday, March 22, 2024 06:30 AM"
                android:textSize="14sp"
                android:textColor="@color/light_gray"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_delete_run_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="Delete This Cloud Run"
                android:textColor="@color/accent_red"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Performance Score -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Performance Score"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_performance_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_green"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="@color/gray" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:id="@+id/tv_run_compare_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="vs Your Avg"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_run_compare_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+12%"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_green"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Main Metrics Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dark_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Main Metrics"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:layout_marginTop="12dp"
                android:columnOrderPreserved="false">

                <!-- Distance -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_distance_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.23 km"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Duration -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Duration"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_duration_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="35m 42s"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Average Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avg Speed"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_avg_speed_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.8 km/h"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Max Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Max Speed"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_max_speed_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12.3 km/h"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Pace -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_columnSpan="2">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pace"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_pace_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6:49 /km"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dark_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Route Map"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <FrameLayout
                android:id="@+id/run_route_map_container"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Pace Consistency Chart -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dark_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pace Consistency"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/pace_consistency_chart"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Heart Rate Zones Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dark_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Heart Rate Zones"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zone Distribution"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_zone_distribution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="60% Easy"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time in Zone"
                        android:textSize="12sp"
                        android:textColor="@color/light_gray" />

                    <TextView
                        android:id="@+id/tv_zone_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="48m 12s"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_heart_rate_zone_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zone 2: Light (68%)"
                android:textSize="14sp"
                android:textColor="@color/accent_orange"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Detailed Stats Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dark_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detailed Statistics"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <!-- Steps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Steps"
                    android:textSize="14sp"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_steps_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7,234 steps"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue" />
            </LinearLayout>

            <!-- Calories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Calories Burned"
                    android:textSize="14sp"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_calories_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="520 cal"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_red" />
            </LinearLayout>

            <!-- Calorie Progress Bar -->
            <ProgressBar
                android:id="@+id/calorie_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="8dp"
                android:progress="100"
                android:max="100"
                android:progressTint="@color/accent_blue" />

            <!-- Stride Length -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stride Length"
                    android:textSize="14sp"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_stride_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.72 m"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue" />
            </LinearLayout>

            <!-- Cadence -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cadence"
                    android:textSize="14sp"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_cadence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="168 steps/min"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue" />
            </LinearLayout>

            <!-- Recovery Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recovery Time"
                    android:textSize="14sp"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tv_recovery_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2-4 hours"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Padding -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />
    </LinearLayout>
</ScrollView>
