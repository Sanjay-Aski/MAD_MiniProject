<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top Row: Run Type & Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_run_type"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Run"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tv_run_list_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="12sp"
                android:textColor="@color/light_gray" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_delete_run"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="Delete Cloud Data"
            android:textColor="@color/accent_red"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Metrics Row: Distance, Duration, Pace, Calories -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <!-- Distance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance"
                    android:textSize="10sp"
                    android:textColor="@color/light_gray" />

                <TextView
                    android:id="@+id/tv_run_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00 km"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Duration -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duration"
                    android:textSize="10sp"
                    android:textColor="@color/light_gray" />

                <TextView
                    android:id="@+id/tv_run_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0s"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_orange"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Pace -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pace"
                    android:textSize="10sp"
                    android:textColor="@color/light_gray" />

                <TextView
                    android:id="@+id/tv_run_pace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00 /km"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_green"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Calories -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textSize="10sp"
                    android:textColor="@color/light_gray" />

                <TextView
                    android:id="@+id/tv_run_calories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 cal"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_red"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
